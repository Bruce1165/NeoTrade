def test_directory_structure():
    """测试目录结构"""
    logger.info("\n" + "="*60)
    logger.info("测试目录结构")
    logger.info("="*60)
    
    try:
        expected_dirs = [
            'data/screeners/coffee_cup',
            'data/screeners/coffee_cup/charts',
            'data/screeners/jin_feng_huang',
            'data/screeners/jin_feng_huang/charts',
            'data/screeners/yin_feng_huang',
            'data/screeners/yin_feng_huang/charts',
            'data/screeners/shi_pan_xian',
            'data/screeners/shi_pan_xian/charts',
            'data/screeners/er_ban_hui_tiao',
            'data/screeners/er_ban_hui_tiao/charts',
            'data/screeners/zhang_ting_bei_liang_yin',
            'data/screeners/zhang_ting_bei_liang_yin/charts',
        ]
        
        all_exist = True
        for dir_path in expected_dirs:
            full_path = os.path.join('/Users/mac/.openclaw/workspace-neo', dir_path)
            exists = os.path.exists(full_path)
            status = "✓" if exists else "✗"
            logger.info(f"{status} {dir_path}")
            if not exists:
                all_exist = False
        
        if all_exist:
            logger.info("✓ 目录结构测试通过")
        else:
            logger.warning("部分目录不存在，将在首次运行时创建")
        
        return True
        
    except Exception as e:
        logger.error(f"✗ 目录结构测试失败: {e}")
        return False


def run_all_tests():
    """运行所有测试"""
    logger.info("\n" + "="*80)
    logger.info("开始运行所有测试")
    logger.info("="*80)
    
    tests = [
        ("目录结构", test_directory_structure),
        ("交易日历模块", test_trading_calendar),
        ("新闻抓取模块", test_news_fetcher),
        ("LLM分析模块", test_llm_analyzer),
        ("进度跟踪模块", test_progress_tracker),
        ("输出管理模块", test_output_manager),
        ("基础筛选器类", test_base_screener),
        ("咖啡杯筛选器", test_coffee_cup_screener),
    ]
    
    results = []
    for name, test_func in tests:
        try:
            result = test_func()
            results.append((name, result))
        except Exception as e:
            logger.error(f"测试 {name} 发生异常: {e}")
            results.append((name, False))
    
    # 打印汇总
    logger.info("\n" + "="*80)
    logger.info("测试结果汇总")
    logger.info("="*80)
    
    passed = sum(1 for _, result in results if result)
    total = len(results)
    
    for name, result in results:
        status = "✓ 通过" if result else "✗ 失败"
        logger.info(f"{status}: {name}")
    
    logger.info("="*80)
    logger.info(f"总计: {passed}/{total} 项测试通过")
    logger.info("="*80)
    
    return passed == total


if __name__ == '__main__':
    success = run_all_tests()
    sys.exit(0 if success else 1)
