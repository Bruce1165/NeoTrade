def test_llm_analyzer():
    """测试LLM分析模块"""
    logger.info("\n" + "="*60)
    logger.info("测试LLM分析模块")
    logger.info("="*60)
    
    try:
        from llm_analyzer import LLMAnalyzer
        
        analyzer = LLMAnalyzer()
        
        # 测试分析单只股票
        test_code = "600519"
        test_name = "贵州茅台"
        test_news = """
1. [2026-03-13] 贵州茅台发布2025年年报，净利润同比增长15%
2. [2026-03-12] 白酒板块整体走强，茅台领涨
3. [2026-03-10] 茅台推出新品，市场反响热烈
"""
        
        logger.info(f"测试分析 {test_code} {test_name}...")
        
        result = analyzer.analyze_stock(test_code, test_name, test_news, use_cache=False)
        
        logger.info("分析结果:")
        for key, value in result.items():
            logger.info(f"  {key}: {value}")
        
        logger.info("✓ LLM分析模块测试通过")
        return True
        
    except Exception as e:
        logger.error(f"✗ LLM分析模块测试失败: {e}")
