                logger.info(f"  - {item.get('title', 'N/A')[:50]}...")
        else:
            logger.warning("未获取到新闻（可能网络问题）")
        
        # 测试新闻摘要
        summary = fetcher.get_news_summary(test_code, max_news=3)
        logger.info(f"新闻摘要:\n{summary[:100]}...")
        
        logger.info("✓ 新闻抓取模块测试通过")
        return True
        
    except Exception as e:
