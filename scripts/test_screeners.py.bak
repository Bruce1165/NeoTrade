def test_progress_tracker():
    """测试进度跟踪模块"""
    logger.info("\n" + "="*60)
    logger.info("测试进度跟踪模块")
    logger.info("="*60)
    
    try:
        from progress_tracker import ProgressTracker
        
        tracker = ProgressTracker('test_screener')
        
        # 重置进度
        tracker.reset()
        
        # 开始任务
        tracker.start(total_stocks=1000, metadata={'date': '2026-03-14'})
        logger.info("进度跟踪已启动")
        
        # 模拟处理
        for i in range(10):
            tracker.update(
                processed=i+1,
                matched=i//3,
                current_code=f'600{i:03d}'
            )
        
        # 添加匹配的股票
        tracker.add_matched_code('600001')
        tracker.add_matched_code('600002')
        
        # 获取进度摘要
        summary = tracker.get_summary()
        logger.info("进度摘要:")
        for key, value in summary.items():
            logger.info(f"  {key}: {value}")
        
        # 完成任务
        tracker.complete(success=True)
        logger.info("进度跟踪已完成")
        
        logger.info("✓ 进度跟踪模块测试通过")
        return True
        
    except Exception as e:
        logger.error(f"✗ 进度跟踪模块测试失败: {e}")
        return False


def test_output_manager():
    """测试输出管理模块"""
    logger.info("\n" + "="*60)
    logger.info("测试输出管理模块")
    logger.info("="*60)
    
    try:
        from output_manager import OutputManager
        
        manager = OutputManager('test_screener')
        
        # 测试数据
        test_results = [
            {'code': '600519', 'name': '贵州茅台', 'close': 1800.0, 'pct_change': 2.5},
            {'code': '000001', 'name': '平安银行', 'close': 12.5, 'pct_change': 1.8},
        ]
        
        # 测试保存结果
        output_path = manager.save_results(test_results, suffix='test')
        logger.info(f"结果已保存: {output_path}")
        
        # 测试带分析数据保存
        analysis_data = {
            '600519': {
                '上涨原因': '业绩超预期',
                '行业分类': '白酒',
                '相关概念': '消费、白酒',
                '新闻摘要': '茅台发布年报，净利润增长15%',
                '分析置信度': '高'
            },
            '000001': {
                '上涨原因': '银行板块走强',
                '行业分类': '银行',
                '相关概念': '金融、银行',
                '新闻摘要': '银行业绩改善',
                '分析置信度': '中'
            }
        }
        
        output_path2 = manager.save_with_analysis(test_results, analysis_data, suffix='with_analysis')
        logger.info(f"带分析的结果已保存: {output_path2}")
        
        # 测试统计
        stats = manager.get_stats()
        logger.info("统计信息:")
        for key, value in stats.items():
            logger.info(f"  {key}: {value}")
        
        # 清理测试文件
        if os.path.exists(output_path):
            os.remove(output_path)
        if os.path.exists(output_path2):
            os.remove(output_path2)
        
        logger.info("✓ 输出管理模块测试通过")
        return True
        
    except Exception as e:
        logger.error(f"✗ 输出管理模块测试失败: {e}")
        return False


def test_base_screener():
    """测试基础筛选器类"""
    logger.info("\n" + "="*60)
    logger.info("测试基础筛选器类")
    logger.info("="*60)
    
    try:
        from base_screener import BaseScreener
        
        # 创建测试筛选器
        class TestScreener(BaseScreener):
            def screen_stock(self, code, name):
                df = self.get_stock_data(code, days=5)
                if df is not None and len(df) >= 2:
                    latest = df.iloc[-1]
                    if latest.get('pct_change', 0) > 9:  # 涨停
                        return {
                            'code': code,
                            'name': name,
                            'close': latest['close'],
                            'pct_change': latest['pct_change']
                        }
                return None
        
        screener = TestScreener(
            screener_name='test',
            enable_news=False,
            enable_llm=False,
            enable_progress=False
        )
        
        # 测试获取股票数据
        test_code = "600519"
        df = screener.get_stock_data(test_code, days=10)
        
        if df is not None:
            logger.info(f"获取到 {test_code} 的 {len(df)} 天数据")
            logger.info(f"最近一天数据: {df.iloc[-1].to_dict()}")
        
        # 测试获取所有股票
        stocks = screener.get_all_stocks()
        logger.info(f"获取到 {len(stocks)} 只股票")
        
        # 测试统计
        stats = screener.get_stats()
        logger.info(f"统计信息: {stats}")
        
        logger.info("✓ 基础筛选器类测试通过")
        return True
        
    except Exception as e:
        logger.error(f"✗ 基础筛选器类测试失败: {e}")
        import traceback
        traceback.print_exc()
        return False


