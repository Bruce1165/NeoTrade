def test_trading_calendar():
    """测试交易日历模块"""
    logger.info("\n" + "="*60)
    logger.info("测试交易日历模块")
    logger.info("="*60)
    
    try:
        from trading_calendar import TradingCalendar, get_recent_trading_day
        
        calendar = TradingCalendar()
        
        # 测试是否为交易日
        test_date = datetime.now()
        logger.info(f"今天 ({test_date.strftime('%Y-%m-%d')}) 是交易日: {calendar.is_trading_day(test_date)}")
        
        # 测试获取最近交易日
        recent_day = calendar.get_recent_trading_day()
        logger.info(f"最近交易日: {recent_day}")
        
        # 测试获取N个交易日前的日期
        five_days_ago = calendar.get_n_trading_days_ago(5)
        logger.info(f"5个交易日前的日期: {five_days_ago}")
        
        # 测试获取交易日窗口
        window = calendar.get_trading_days_window(recent_day, 10)
        logger.info(f"最近10个交易日: {window}")
        
        logger.info("✓ 交易日历模块测试通过")
        return True
        
    except Exception as e:
        logger.error(f"✗ 交易日历模块测试失败: {e}")
        return False


