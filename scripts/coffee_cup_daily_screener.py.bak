#!/usr/bin/env python3
"""
Coffee Cup Screener Daily Task - 咖啡杯形态每日筛选任务（合并版）
Triggered task for dashboard - 手动触发

功能：
1. 检查数据更新状态，100%完成后才运行筛选
2. 运行咖啡杯形态筛选
3. 输出到两个位置：
   - data/coffee_cup_YYYYMMDD.xlsx（基础字段）
   - data/coffee_cup_daily/YYYYMMDD/咖啡杯形态选股.xlsx（丰富字段，包含市值、行业等）
"""

import os
import sys
import json
import logging
import subprocess
import pandas as pd
from datetime import datetime
from pathlib import Path

# Add workspace to path
WORKSPACE_ROOT = Path(__file__).parent.parent
sys.path.insert(0, str(WORKSPACE_ROOT))
sys.path.insert(0, str(WORKSPACE_ROOT / "scripts"))

from database import init_db, get_session, Stock


class CoffeeCupDailyScreener:
    """咖啡杯形态每日筛选任务（合并版）"""
    
    def __init__(self):
        self.logger = self._setup_logging()
        self.progress_file = WORKSPACE_ROOT / 'data' / 'daily_update_progress.json'
        self.coffee_cup_script = WORKSPACE_ROOT / 'coffee_cup_screener.py'
        self.data_dir = WORKSPACE_ROOT / 'data' / 'coffee_cup_daily'
        self.engine = init_db()
        self.session = get_session(self.engine)
    
    def _setup_logging(self):
        """设置日志"""
        logger = logging.getLogger('coffee_cup_daily_task')
        if not logger.handlers:
            handler = logging.StreamHandler()
            handler.setFormatter(logging.Formatter('%(asctime)s - %(levelname)s - %(message)s'))
            logger.addHandler(handler)
            logger.setLevel(logging.INFO)
        return logger
    
    def _check_update_status(self):
        """检查数据更新状态"""
        if not self.progress_file.exists():
            return {'status': 'not_started', 'completion_rate': 0, 'message': 'No progress file found'}
        
        with open(self.progress_file, 'r') as f:
            progress = json.load(f)
        
        status = progress.get('status', 'unknown')
        planned = progress.get('planned', 0)
        completed = len(progress.get('completed', []))
        completion_rate = progress.get('completion_rate', 0)
        last_update = progress.get('last_update')
        
        if planned > 0:
            completion_rate = (completed / planned) * 100
        
        return {
            'status': status,
            'planned': planned,
            'completed': completed,
            'completion_rate': completion_rate,
            'last_update': last_update,
            'ready': status == 'completed' and completion_rate >= 100
        }
    
    def _enrich_data(self, df):
        """从数据库补充市值、行业等字段"""
        results = []
        
        for _, row in df.iterrows():
            code = str(row.get('股票代码', ''))
            name = str(row.get('股票名称', ''))
            
            # 从数据库获取补充信息
            stock = self.session.query(Stock).filter_by(code=code).first()
            
            results.append({
                '代码': code,
                '名称': name,
                '杯沿': round(float(row.get('杯沿', 0)), 2) if '杯沿' in row else None,
                '杯柄': round(float(row.get('杯柄', 0)), 2) if '杯柄' in row else None,
                '杯底': round(float(row.get('杯底', 0)), 2) if '杯底' in row else None,
                '收盘价': round(float(row.get('收盘价', 0)), 2),
                '涨幅%': round(float(row.get('涨幅%', 0)), 2),
                '换手率%': round(float(row.get('换手率%', 0)), 2),
                '量比': round(float(row.get('量比', 0)), 2),
                '总金额(亿)': round(float(row.get('总金额', 0)) / 1e8, 2) if '总金额' in row else None,
                'AB股总市值(亿)': round(stock.total_market_cap / 1e8, 2) if stock and stock.total_market_cap else None,
                '流通市值(亿)': round(stock.circulating_market_cap / 1e8, 2) if stock and stock.circulating_market_cap else None,
                '行业': stock.industry if stock and stock.industry else row.get('所属行业', ''),
                '市净率': round(stock.pb_ratio, 2) if stock and stock.pb_ratio else None
            })
        
        return pd.DataFrame(results)
    
    def _save_enriched_output(self, df, target_date):
        """保存丰富字段的输出"""
        save_dir = self.data_dir / target_date
        save_dir.mkdir(parents=True, exist_ok=True)
        
        filepath = save_dir / '咖啡杯形态选股.xlsx'
        
        with pd.ExcelWriter(filepath, engine='openpyxl') as writer:
            df.to_excel(writer, sheet_name='咖啡杯形态', index=False)
        
        self.logger.info(f"丰富字段Excel已保存: {filepath}")
        return filepath
    
    def run_screening(self, target_date: str = None):
        """运行咖啡杯每日筛选任务"""
        if target_date is None:
            target_date = datetime.now().strftime('%Y-%m-%d')
        
        self.logger.info("="*60)
        self.logger.info(f"开始咖啡杯每日筛选任务: {target_date}")
        self.logger.info("="*60)
        
        # 检查数据更新状态
        self.logger.info("检查数据更新状态...")
        status = self._check_update_status()
        
        self.logger.info(f"更新状态: {status['status']}")
        self.logger.info(f"完成率: {status['completion_rate']:.1f}%")
        self.logger.info(f"已完成: {status['completed']}/{status['planned']}")
        
        if not status['ready']:
            message = f"数据更新未完成 ({status['completion_rate']:.1f}%)，跳过筛选"
            self.logger.warning(message)
            return [{
                'code': 'STATUS',
                'name': 'Skipped',
                'message': message,
                'completion_rate': status['completion_rate'],
                'completed': status['completed'],
                'planned': status['planned']
            }]
        
        self.logger.info("✓ 数据更新 100% 完成，运行咖啡杯筛选器...")
        
        try:
            # 运行咖啡杯筛选器
            result = subprocess.run(
                ['python3', str(self.coffee_cup_script)],
                capture_output=True,
                text=True,
                cwd=str(WORKSPACE_ROOT)
            )
            
            self.logger.info(result.stdout)
            
            if result.returncode != 0:
                error_msg = f"咖啡杯筛选器执行失败: {result.stderr}"
                self.logger.error(error_msg)
                raise Exception(error_msg)
            
            # 解析结果文件
            result_file = WORKSPACE_ROOT / 'data' / f'coffee_cup_{target_date}.xlsx'
            
            if not result_file.exists():
                # 尝试找最新的结果文件
                data_dir = WORKSPACE_ROOT / 'data'
                coffee_cup_files = sorted(data_dir.glob('coffee_cup_*.xlsx'), reverse=True)
                
                if coffee_cup_files:
                    result_file = coffee_cup_files[0]
                    self.logger.info(f"使用最新结果文件: {result_file.name}")
                else:
                    self.logger.warning("未找到结果文件")
                    return [{
                        'code': 'STATUS',
                        'name': 'No Results',
                        'message': 'Screener completed but no results file found'
                    }]
            
            # 读取数据
            df = pd.read_excel(result_file)
            
            if df.empty:
                self.logger.warning("咖啡杯筛选结果为空")
                return []
            
            self.logger.info(f"读取到 {len(df)} 只咖啡杯形态股票")
            
            # 补充丰富字段
            self.logger.info("补充市值、行业等字段...")
            enriched_df = self._enrich_data(df)
            
            # 保存丰富字段输出
            self._save_enriched_output(enriched_df, target_date)
            
            # 返回基础字段结果（兼容Dashboard）
            results = []
            for _, row in df.iterrows():
                results.append({
                    'code': str(row.get('股票代码', '')),
                    'name': str(row.get('股票名称', '')),
                    'close': round(float(row.get('收盘价', 0)), 2),
                    'pct_change': round(float(row.get('涨幅%', 0)), 2),
                    'turnover': round(float(row.get('换手率%', 0)), 2),
                    'cup_rim': round(float(row.get('杯沿', 0)), 2) if '杯沿' in row else None,
                    'cup_handle': round(float(row.get('杯柄', 0)), 2) if '杯柄' in row else None,
                    'cup_bottom': round(float(row.get('杯底', 0)), 2) if '杯底' in row else None,
                    'volume_ratio': round(float(row.get('量比', 0)), 2) if '量比' in row else None
                })
            
            self.logger.info(f"✓ 咖啡杯筛选完成: 找到 {len(results)} 只股票")
            return results
                    
        except Exception as e:
            self.logger.error(f"咖啡杯筛选失败: {e}")
            raise


def main():
    """主函数"""
    screener = CoffeeCupDailyScreener()
    results = screener.run_screening()
    
    if results:
        if results[0].get('code') == 'STATUS':
            print(f"\n状态: {results[0].get('name')}")
            print(f"消息: {results[0].get('message', '')}")
        else:
            print(f"\n找到 {len(results)} 只咖啡杯形态股票")
            for r in results[:5]:
                print(f"  {r['code']} {r['name']}: 涨幅{r['pct_change']:.2f}%")


if __name__ == '__main__':
    main()
